<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Online Bookstore</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <header class="navbar">
        <div class="nav-container">

            <!-- LEFT -->
            <div class="nav-left">
                <h1 class="nav-logo">📖 BookVault</h1>
            </div>

            <!-- CENTER -->
            <ul class="nav-menu">
                <li><a href="/" class="nav-link">Home</a></li>
                <li><a href="/books" class="nav-link">Books</a></li>
                <li><a href="/categories" class="nav-link">Categories</a></li>
                <li><a href="/about" class="nav-link">About</a></li>
                <li><a href="/contact" class="nav-link">Contact</a></li>
                <li><a href="/feedback" class="nav-link">Feedback</a></li>
            </ul>

            <!-- RIGHT -->
            <div class="nav-right">
                <a href="/cart" class="nav-icon">🛒</a>

                <% if (currentUser) { %>
                    <a href="/books/add" class="btn-add">+ Add</a>
                    <span class="nav-user">👤 <%= currentUser.username %></span>
                    <a href="/logout" class="nav-link logout">Logout</a>
                <% } else { %>
                    <a href="/login" class="nav-link">Login</a>
                    <a href="/signup" class="btn-signup">Signup</a>
                <% } %>
            </div>
        </div>

        <!-- SEARCH -->
        <div class="search-container">
            <form action="/books/search" method="GET" class="search-form">
                <input type="text" name="q" placeholder="🔍 Search books..." class="search-input">
                <button type="submit" class="search-btn">Search</button>
            </form>
        </div>
    </header>
    <main class="container">