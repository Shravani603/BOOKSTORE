<%- include('partials/header') %>

<div class="container">
    <h1>Your Shopping Cart</h1>

    <% if (cart && cart.length > 0) { %>
        <div class="cart-grid">
            <% cart.forEach((book, index) => { %>
                <div class="cart-item">
                    <img src="<%= book.imageUrl %>" alt="<%= book.title %>" class="cart-image">
                    <div class="cart-info">
                        <h3><%= book.title %></h3>
                        <p>By <%= book.author %></p>
                        <p>Category: <%= book.category %></p>
                        <p>Price: ₹<%= book.price.toFixed(2) %></p>
                    </div>

                    <form action="/cart/remove/<%= index %>" method="POST" class="remove-form">
                        <button type="submit" class="btn btn-delete">Remove</button>
                    </form>
                </div>
            <% }); %>
        </div>

        <div class="cart-summary">
            <h3>Total: ₹<%= cart.reduce((sum, b) => sum + b.price, 0).toFixed(2) %></h3>
            <form action="/cart/checkout" method="POST">
                <button type="submit" class="btn btn-primary">Proceed to Checkout</button>
            </form>
        </div>
    <% } else { %>
        <div class="empty-cart">
            <h3>Your cart is empty.</h3>
            <a href="/books" class="btn btn-secondary">Browse Books</a>
        </div>
    <% } %>
</div>

<%- include('partials/footer') %>
