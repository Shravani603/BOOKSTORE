<%- include('partials/header') %>

<div class="auth-container">
    <div class="auth-card">
        <h2>Edit Feedback</h2>

        <form action="/feedback/<%= feedback._id %>?_method=PUT" method="POST">

            <div class="form-group">
                <label>Your Name</label>
                <input type="text" name="customerName" value="<%= feedback.customerName %>" required>
            </div>

            <div class="form-group">
                <label>Rating</label>
                <select name="rating" required>
                    <option value="5" <%= feedback.rating == 5 ? 'selected' : '' %>>⭐⭐⭐⭐⭐</option>
                    <option value="4" <%= feedback.rating == 4 ? 'selected' : '' %>>⭐⭐⭐⭐</option>
                    <option value="3" <%= feedback.rating == 3 ? 'selected' : '' %>>⭐⭐⭐</option>
                    <option value="2" <%= feedback.rating == 2 ? 'selected' : '' %>>⭐⭐</option>
                    <option value="1" <%= feedback.rating == 1 ? 'selected' : '' %>>⭐</option>
                </select>
            </div>

            <div class="form-group">
                <label>Book Title</label>
                <input type="text" name="bookTitle" value="<%= feedback.bookTitle %>">
            </div>

            <div class="form-group">
                <label>Your Review</label>
                <textarea name="review" rows="4" required><%= feedback.review %></textarea>
            </div>

            <button type="submit" class="btn btn-primary">Update</button>
        </form>

    </div>
</div>

<%- include('partials/footer') %>